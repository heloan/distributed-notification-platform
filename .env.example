# Environment Configuration
# =============================================================================
# Copy this file to .env and update with your values
# =============================================================================

# PostgreSQL
POSTGRES_DB=dsnp
POSTGRES_USER=dsnp_user
POSTGRES_PASSWORD=dsnp_password

# Kafka
KAFKA_BOOTSTRAP_SERVERS=kafka:29092

# API Gateway
ASPNETCORE_ENVIRONMENT=Development
EVENT_SERVICE_BASE_URL=http://event-service:8080

# Event Service (Java)
SPRING_DATASOURCE_URL=jdbc:postgresql://postgres:5432/dsnp
SPRING_DATASOURCE_USERNAME=dsnp_user
SPRING_DATASOURCE_PASSWORD=dsnp_password
SPRING_KAFKA_BOOTSTRAP_SERVERS=kafka:29092

# Notification Service
DOTNET_ENVIRONMENT=Development
NOTIFICATION_DB_CONNECTION=Host=postgres;Port=5432;Database=dsnp;Username=dsnp_user;Password=dsnp_password

# Grafana
GF_SECURITY_ADMIN_USER=admin
GF_SECURITY_ADMIN_PASSWORD=admin
