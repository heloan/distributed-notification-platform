# ============================================================================
# Distributed Smart Notification Platform
# EditorConfig — Consistent coding style across .NET and Java
# https://editorconfig.org
# ============================================================================

root = true

# --------------------------------------------------------------------------
# Default settings for all files
# --------------------------------------------------------------------------
[*]
charset = utf-8
end_of_line = lf
indent_style = space
indent_size = 4
insert_final_newline = true
trim_trailing_whitespace = true

# --------------------------------------------------------------------------
# C# files
# --------------------------------------------------------------------------
[*.cs]
indent_size = 4

# C# code style — namespace declarations
csharp_style_namespace_declarations = file_scoped:suggestion

# C# code style — using directives
dotnet_sort_system_directives_first = true
dotnet_separate_import_directive_groups = false

# --------------------------------------------------------------------------
# Java files
# --------------------------------------------------------------------------
[*.java]
indent_size = 4

# --------------------------------------------------------------------------
# XML / CSPROJ / Props
# --------------------------------------------------------------------------
[*.{xml,csproj,props,targets}]
indent_size = 2

# --------------------------------------------------------------------------
# JSON / YAML / YML
# --------------------------------------------------------------------------
[*.{json,yml,yaml}]
indent_size = 2

# --------------------------------------------------------------------------
# Markdown
# --------------------------------------------------------------------------
[*.md]
trim_trailing_whitespace = false

# --------------------------------------------------------------------------
# Docker
# --------------------------------------------------------------------------
[Dockerfile]
indent_size = 4

# --------------------------------------------------------------------------
# Shell scripts
# --------------------------------------------------------------------------
[*.sh]
indent_size = 2
end_of_line = lf

# --------------------------------------------------------------------------
# Properties files (Java)
# --------------------------------------------------------------------------
[*.properties]
indent_size = 4
