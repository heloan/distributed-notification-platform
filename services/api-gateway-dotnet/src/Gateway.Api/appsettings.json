{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "System.Net.Http.HttpClient": "Warning"
    }
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft.AspNetCore": "Warning",
        "System.Net.Http.HttpClient": "Warning"
      }
    }
  },
  "EventService": {
    "BaseUrl": "http://event-service:8080",
    "TimeoutSeconds": 30,
    "RetryCount": 3,
    "CircuitBreakerDurationSeconds": 30
  },
  "AllowedHosts": "*"
}
